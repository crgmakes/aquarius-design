        <mxCell id="pNhvp4f_uqebVZAM0Znj-183" parent="pNhvp4f_uqebVZAM0Znj-181" style="dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;shape=mxgraph.gmdl.slider2;barPos=38.21;strokeColor=#3F51B5;opacity=100;strokeWidth=2;fillColor=#3F51B5;handleSize=10;shadow=0;html=1;" value="" vertex="1">

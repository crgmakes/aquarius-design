        </mxCell>
        <mxCell id="kd-PokEqY_vniWFkHKjl-26" parent="67oTpgEa2WXzzzEcvGrF-1" style="rounded=0;whiteSpace=wrap;html=1;" value="Deactive" vertex="1">
          <mxGeometry height="20" width="80" x="420" y="1081" as="geometry" />
        </mxCell>
        <mxCell id="kd-PokEqY_vniWFkHKjl-41" parent="67oTpgEa2WXzzzEcvGrF-1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Trigger Value in Routine?&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Do we put the value trigger in the routine?&lt;/li&gt;&lt;li&gt;Provides more flexibility but complicates doing simple things like simple on/off routines&lt;/li&gt;&lt;li&gt;Maybe have a wizard to do simple one and off?&lt;/li&gt;&lt;li&gt;Ask at the end to automatically invert the trigger and action?&lt;/li&gt;&lt;li&gt;If we put the trigger value here, we have to run through EVERY routine EACH time we sample the peripheral. That&#39;s A LOT of cycles.&lt;/li&gt;&lt;ul&gt;&lt;li&gt;We can put routine triggers into sensor trigger list to make it easier&lt;/li&gt;&lt;/ul&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" vertex="1">

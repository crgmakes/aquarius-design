        <mxCell id="pNhvp4f_uqebVZAM0Znj-185" parent="67oTpgEa2WXzzzEcvGrF-1" style="text;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;div style=&quot;font-size: 12px; line-height: 18px; white-space: pre;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;&quot; face=&quot;Caros&quot;&gt;&lt;b&gt;/** &lt;/b&gt;&lt;/font&gt;&lt;b style=&quot;font-family: Caros; background-color: initial;&quot;&gt;SENSORS &lt;/b&gt;&lt;b style=&quot;font-family: Caros; background-color: initial;&quot;&gt; **/&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: normal;&quot;&gt;&lt;font face=&quot;Caros&quot;&gt;CURRENT,&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: normal;&quot;&gt;&lt;font face=&quot;Caros&quot;&gt;LIGHT,&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: normal;&quot;&gt;&lt;font face=&quot;Caros&quot;&gt;DISTANCE,&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: normal;&quot;&gt;&lt;div&gt;&lt;font face=&quot;Caros&quot;&gt;ENV,&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-family: Caros; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;PARTICLE,&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: normal;&quot;&gt;&lt;font face=&quot;Caros&quot;&gt;IR_RX,&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: normal;&quot;&gt;&lt;font face=&quot;Caros&quot;&gt;RF_RX,&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="120" x="400" y="398" as="geometry" />
        </mxCell>
        <mxCell id="pNhvp4f_uqebVZAM0Znj-186" parent="67oTpgEa2WXzzzEcvGrF-1" style="text;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;div style=&quot;font-size: 12px; line-height: 18px; white-space: pre;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;&quot; face=&quot;Caros&quot;&gt;&lt;b&gt;/** PERIPHERALS&lt;/b&gt;&lt;/font&gt;&lt;b style=&quot;font-family: Caros; background-color: initial;&quot;&gt; **/&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: normal;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-family: Caros; background-color: initial;&quot;&gt;SERVO&lt;/span&gt;&lt;span style=&quot;font-family: Caros; background-color: initial;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;font-family: Caros; background-color: initial;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;font-family: Caros; background-color: initial;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;font-family: Caros; background-color: initial;&quot;&gt;1&lt;/span&gt;&lt;span style=&quot;font-family: Caros; background-color: initial;&quot;&gt;,&lt;/span&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font face=&quot;Caros&quot;&gt;MOTOR = 2,&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font face=&quot;Caros&quot;&gt;RELAY = 3,&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font face=&quot;Caros&quot;&gt;IR_TX = 4,&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font face=&quot;Caros&quot;&gt;RF_TX = 5,&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="130" x="530" y="398" as="geometry" />
        </mxCell>
        <mxCell id="pNhvp4f_uqebVZAM0Znj-187" parent="67oTpgEa2WXzzzEcvGrF-1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=30;fontStyle=1" value="Option 1" vertex="1">
          <mxGeometry height="150" width="150" x="10" y="741" as="geometry" />
        </mxCell>
        <mxCell id="pNhvp4f_uqebVZAM0Znj-188" parent="67oTpgEa2WXzzzEcvGrF-1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=30;fontStyle=1" value="Option 2" vertex="1">
          <mxGeometry height="150" width="150" x="780" y="1351" as="geometry" />
        </mxCell>
        <mxCell id="pNhvp4f_uqebVZAM0Znj-189" parent="67oTpgEa2WXzzzEcvGrF-1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Problems&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Particle sensor has 3 different measurement values -- are they &quot;indices&quot; or entirely different sensors?&lt;/li&gt;&lt;li&gt;Particle sensor might need many different trigger values&lt;/li&gt;&lt;li&gt;Need two triggers for a single sensor - one to activate, one to deactivate&lt;/li&gt;&lt;li&gt;Each particle sensor value will be it&#39;s own value&lt;/li&gt;&lt;li&gt;&amp;nbsp;- PM1, PM2.5, PM4.0, PM10, VOC, NOX, humidity, temperature&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;Sensor trigger &quot;value&quot; needs to be tailored to sensor type - e.g., IR or RF might need to save a HEX code as trigger value rather than an analog value (acknowledging a hex code is an analog value when converted to binary)&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;Sensor Action value need to include &#39;send command&#39; and associated command values if peripheral is RF or IR&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="310" width="460" x="1636" y="991" as="geometry" />
        </mxCell>
        <mxCell id="pNhvp4f_uqebVZAM0Znj-190" parent="67oTpgEa2WXzzzEcvGrF-1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Decisions&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Routine can send an action to any client/peripheral combo&lt;/li&gt;&lt;li&gt;Routine can be triggered by any number of conditions&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Once a routine fires, it is locked from additional action until the sensor value passes the reset threshold in the proper direction.&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="270" width="480" x="2680" y="920" as="geometry" />
        </mxCell>
        <mxCell id="pNhvp4f_uqebVZAM0Znj-191" parent="67oTpgEa2WXzzzEcvGrF-1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;" value="" vertex="1">
